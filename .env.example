# ─── Supabase (added in #131, expanded in #152) ─────────────────────
# Project URL — `https://<project-ref>.supabase.co`
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key. Either the legacy JWT (`eyJ...`) or the
# modern publishable form (`sb_publishable_...`) works. Safe to ship
# to the browser; RLS protects writes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. SERVER ONLY — bypasses RLS. Used by the admin
# write routes (`/api/admin/movement-benchmarks/*`). Never expose
# this on the client; never check it into git.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of admin emails, e.g. "lucasklawrence@gmail.com".
# SERVER ONLY — the browser learns admin status by calling
# `/api/admin/check`, which returns only a boolean. Never expose the
# raw list with a `NEXT_PUBLIC_` prefix.
ADMIN_EMAILS=

# ─── Personal telemetry (#220) ──────────────────────────────────────
# App-health + business events published to the `telemetry` Pub/Sub
# topic in koy-engineering, landing in BigQuery `telemetry.events`.
# See lucasklawrence/life docs/personal-telemetry-PRD.md §5.

# Logical project name. Must be `courtfolio` so `source='app'` rows
# join the `source='claude-code'` rows for this project in Grafana.
TELEMETRY_PROJECT=courtfolio

# Deploy environment label: `prod` on Vercel production, `preview` on
# preview deploys, `local` (the default when unset) for dev.
TELEMETRY_ENV=local

# GCP project that owns the `telemetry` topic.
GOOGLE_CLOUD_PROJECT=koy-engineering

# Service-account key JSON (the whole file, pasted as one value).
# SERVER ONLY — used on Vercel, where Application Default Credentials
# can't read a key file. Locally, prefer leaving this unset and using
# `GOOGLE_APPLICATION_CREDENTIALS=<path to key file>` instead.
GCP_SA_KEY=

# Set to 1 to fully no-op every telemetry call (tests/CI set this;
# also handy locally to avoid publishing dev noise).
TELEMETRY_DISABLED=
