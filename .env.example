# ─── Supabase (added in #131, expanded in #152) ─────────────────────
# Project URL — `https://<project-ref>.supabase.co`
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key. Either the legacy JWT (`eyJ...`) or the
# modern publishable form (`sb_publishable_...`) works. Safe to ship
# to the browser; RLS protects writes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. SERVER ONLY — bypasses RLS. Used by the admin
# write routes (`/api/admin/movement-benchmarks/*`). Never expose
# this on the client; never check it into git.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of admin emails, e.g. "lucasklawrence@gmail.com".
# SERVER ONLY — the browser learns admin status by calling
# `/api/admin/check`, which returns only a boolean. Never expose the
# raw list with a `NEXT_PUBLIC_` prefix.
ADMIN_EMAILS=
