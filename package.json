{
  "name": "my-court",
  "version": "0.2.9",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "optimize:svg": "svgo -rf public/locker-room && svgo -rf public/training-facility && svgo -rf public/contact && svgo -rf public/common",
    "import-health": "node scripts/import-health.mjs",
    "cardio:backfill": "node scripts/backfill-cardio.mjs",
    "import-otbeat": "node scripts/import-otbeat.mjs",
    "e2e:dev": "cross-env TELEMETRY_DISABLED=1 NEXT_DIST_DIR=.next-e2e-default NEXT_PUBLIC_ENABLE_TRAINING_FACILITY=false NEXT_PUBLIC_ENABLE_DRAFT_ROOM=false next dev --turbopack --hostname 127.0.0.1 --port 3007",
    "e2e:dev:training-facility": "cross-env TELEMETRY_DISABLED=1 NEXT_DIST_DIR=.next-e2e-training-facility NEXT_PUBLIC_ENABLE_TRAINING_FACILITY=true NEXT_PUBLIC_ENABLE_DRAFT_ROOM=true next dev --turbopack --hostname 127.0.0.1 --port 3008",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "panel": "tsx scripts/panel.ts",
    "panel:bake": "tsx scripts/bake-panel-evidence.ts"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.105.1",
    "@vercel/analytics": "^2.0.1",
    "ai": "^5.0.204",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "framer-motion": "^12.42.2",
    "next": "15.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-simple-typewriter": "^5.0.1",
    "roughjs": "^4.6.6",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "eslint": "10.6.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "tar": "^7.5.3",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "browserslist": {
    "production": [
      "defaults",
      "not IE 11",
      "not Safari < 14"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
